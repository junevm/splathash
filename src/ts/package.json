{
  "name": "splathash-ts",
  "version": "1.3.0",
  "description": "SplatHash: compress any image to 16 bytes and reconstruct it",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/index.cjs",
    "dist/index.mjs",
    "dist/index.d.cts",
    "dist/index.d.mts",
    "README.md"
  ],
  "keywords": [
    "image",
    "hash",
    "perceptual",
    "thumbnail",
    "blurhash"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junevm/splathash.git"
  },
  "scripts": {
    "test": "tsc && node --test dist/test/test.js",
    "build": "tsdown",
    "example": "ts-node examples/simple.ts"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sharp": "^0.31.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5.0.0"
  }
}
